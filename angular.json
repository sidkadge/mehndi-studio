{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "mehndi-studio": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",

      "architect": {
        "build": {
          "builder": "@angular/build:application",

          "options": {
            "outputPath": "dist",

            "browser": "src/main.ts",
            "tsConfig": "tsconfig.app.json",

            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],

            "styles": [
              "src/styles.css"
            ],

            

            "outputMode": "static"

           
          },

          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all"
            },

            "development": {
              "optimization": false,
              "sourceMap": true
            }
          },

          "defaultConfiguration": "production"
        },

        "serve": {
          "builder": "@angular/build:dev-server",

          "configurations": {
            "production": {
              "buildTarget": "mehndi-studio:build:production"
            },

            "development": {
              "buildTarget": "mehndi-studio:build:development"
            }
          },

          "defaultConfiguration": "development"
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}